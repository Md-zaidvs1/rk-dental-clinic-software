# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="http://localhost:3000"

# MONGODB_URI: Connection string for the global MongoDB Atlas database cluster.
# Leave blank to automatically fallback to local JSON/BSON file-based storage.
MONGODB_URI="mongodb+srv://user:password@rk-clinic.xxxxx.mongodb.net/rk_dental?retryWrites=true&w=majority"

# JWT_SECRET: Cryptographic secret key for hashing authentication tokens
JWT_SECRET="rk-dental-super-secret-key-12345"

# JWT_REFRESH_SECRET: Cryptographic secret key for refresh tokens
JWT_REFRESH_SECRET="rk-dental-super-refresh-key-67890"

# UPLOAD_DIR: Disk path for saving patient clinical images and X-Ray uploads
UPLOAD_DIR="./uploads"

# BACKUP_DIR: Local directory path for daily cron DB backups
BACKUP_DIR="./backups"
